{
  "id": "sphinx-chronicle-v1",
  "corpus": "Sphinx Corpus",
  "dataset": "Sphinx Chronicle",
  "version": "1.0.0-registered",
  "status": "registered",
  "research_id": "SPH-T-H005",
  "trial_contract": "configs/trace/sphinx_trace_s0_trial_t0.json",
  "sources": [
    "sphinx-atlas",
    "sphinx-ledger",
    "sphinx-depth",
    "sphinx-web"
  ],
  "primary_key": [
    "condition_id",
    "decision_time",
    "wallet_address"
  ],
  "point_in_time": {
    "decision_time_utc": true,
    "features_published_at_or_before_decision": true,
    "future_features_allowed": false,
    "future_wallet_performance_allowed": false,
    "resolution_labels_joined_after_feature_freeze": true
  },
  "targets": [
    "yes_markout_5m",
    "yes_markout_1h",
    "yes_markout_1d",
    "resolved_yes",
    "resolved_directional_edge",
    "net_edge_proxy"
  ],
  "split": {
    "type": "chronological_event_grouped",
    "random_row_split": false,
    "purge_overlapping_targets": true,
    "untouched_test_required": true,
    "test_labels_opened": false,
    "embargo_days": 7
  },
  "storage": {
    "format": "parquet",
    "partition_by": [
      "event_date",
      "market_category"
    ],
    "raw_data_committed_to_git": false
  }
}
